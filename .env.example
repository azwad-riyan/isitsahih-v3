# IsItSahih v4 — environment variables
# Copy to .env for local `netlify dev`, and set the same keys in the
# Netlify dashboard (Site settings -> Environment variables) for production.
#
# IMPORTANT: these are SERVER-SIDE only. They are read by the Netlify Functions
# and are NEVER exposed to the browser. Do not commit your real .env.

# --- Kalimat semantic search (required) ---
KALIMAT_API_KEY=your_kalimat_api_key

# --- Gemini verdict step (at least one required; up to 6 for quota rotation) ---
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=

# --- Logging to Google Apps Script (optional but recommended) ---
# Web App URL(s) from your Apps Script deployment (see Code.gs).
PRIMARY_LOG_URL=
BACKUP_LOG_URL=

# Netlify sets URL automatically in production; only needed locally if you want
# absolute share links during `netlify dev`.
# URL=http://localhost:8888
